extend type Query {
    agentTools: [ToolInfo!]!
    toolGroups: [ToolGroup!]!
}

extend type Mutation {
    askAgent(input: AgentQueryInput!): AgentQueryResult!
}

input AgentQueryInput {
    question: String!
    collectionId: ID!
    maxIterations: Int = 10
    allowedGroups: [String!]
}

type AgentQueryResult {
    answer: String!
    durationMs: Int!
}

type ToolInfo {
    name: String!
    description: String!
    groups: [String!]!
}

type ToolGroup {
    name: String!
    description: String!
    toolNames: [String!]!
}
