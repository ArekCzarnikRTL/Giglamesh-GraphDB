type PurgeResult {
    collectionsDeleted: Int!
    documentsDeleted: Int!
    ontologiesDeleted: Int!
    kafkaTopicsDeleted: Int!
    durationMs: Int!
}

type OrphanSweepResult {
    quadTablesTruncated: Int!
    vectorCollectionsDeleted: Int!
    blobsDeleted: Int!
}

extend type Mutation {
    purgeAllData: PurgeResult!
    purgeOrphans: OrphanSweepResult!
}
